{
  "name": "venzio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "migrate": "node ./scripts/migrate.js",
    "db:sync": "node ./scripts/sync-local-db.js",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:android": "cap open android",
    "cap:run:android": "JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" cap run android",
    "cap:build:android:debug": "JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" cap sync android && cd android && ./gradlew assembleDebug",
    "android:icons": "bash scripts/generate-android-icons.sh",
    "ios:icons": "bash scripts/generate-ios-icons.sh",
    "cap:ios": "cap open ios",
    "cap:sync:ios": "cap sync ios && cd ios/App && pod install",
    "cap:run:ios": "cap run ios",
    "ios:setup": "bash scripts/setup-ios.sh"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/geolocation": "^7.1.8",
    "@capacitor/ios": "^7.6.5",
    "@capacitor/local-notifications": "^7.0.6",
    "@libsql/client": "^0.14.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "exceljs": "^4.4.0",
    "geo-tz": "^8.1.6",
    "jose": "^6.2.1",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
